[user]
  name = Dmitry Zhelnin
  email = dmitry.zhelnin@gmail.com
[alias]
  s = status
  d = diff
  dc = diff --cached
  amend = commit --amend -C HEAD
  cleanup = !git branch --merged | grep -v -e master -e develop -e \\* | xargs -n 1 git branch -d
  logh = log -1 --format=format:%H
  logo = log --oneline
  logs = log --stat
  pushu = !git push -u origin `git rev-parse --abbrev-ref HEAD`
[color]
  ui = true
[help]
  format = man
  browser = google-chrome
[status]
  showUntrackedFiles = all
[mergetool]
  keepBackup = false
  prompt = false
[merge]
  tool = p4merge
[mergetool "p4merge"]
  path = /usr/local/bin/p4merge
[core]
  excludesfile = ~/.gitignore_global
